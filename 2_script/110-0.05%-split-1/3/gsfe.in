#This is the file to calculate the <111>{110} GSFE curve. The x and y axes are [111] orientation and the {110} normal of the glide plane, respectively.
# ------------------- INITIALIZE -------------------------------
units           metal
dimension	    3
boundary        p s p       
atom_style      atomic

# ------------------- ATOM DEFINE ------------------------------

read_data       ../lmp_input/3/input.lmp
variable        latparam equal 2.834

# ------------------- FIELD DEFINE -----------------------------
pair_style deepmd ../../../0_NNP/FeH.pb # change the potential
pair_coeff * *

neighbor        4.0     bin
neigh_modify every 1 delay 0 check yes

# ------------------- SETTINGS ---------------------------------
variable        fixy equal ${latparam}/sqrt(2.)*5

variable        tmp0 equal "ylo"    
variable        ylo0 equal ${tmp0}+${fixy}
variable        tmp1 equal "yhi"
variable        yhi0 equal ${tmp1}-${fixy}
variable        tmp2 equal "(ylo+yhi)/2"
variable        ymid equal ${tmp2}                         ##### Using ovito to check whether the ymid across an atomic layer??????

region		upbound block INF INF ${yhi0} INF INF INF units box    
region		lobound block INF INF INF ${ylo0} INF INF units box      

group		upbound region upbound
group		lobound region lobound
group		boundary union lobound upbound
group		temp subtract all boundary
group 		hydrogen type 1
group		mobile subtract temp hydrogen


variable        mid equal ${ymid}

region		upper block INF INF ${mid} INF INF INF units box
region		lower block INF INF INF ${mid} INF INF units box
variable        umid equal ${mid}+${fixy}
variable        lmid equal ${mid}-${fixy}
region		Tmiddle block INF INF ${lmid} ${umid} INF INF units box
group		TTmiddle region Tmiddle
group		middle subtract TTmiddle  hydrogen

group		top_tmp region upper
group		bot_tmp region lower

group		top subtract top_tmp hydrogen
group		bot subtract bot_tmp hydrogen # Tang method,  H don't move with Fe


variable        Nslip equal 1
variable        stepn equal 10
variable        stepm equal ${Nslip}*${stepn}+1

variable        area equal lx*lz

variable        disp equal (${latparam}*sqrt(3)/2)/${stepn}/2
variable        dy equal ${fixy}/5*3
displace_atoms  hydrogen move 0 ${disp} 0 units box
displace_atoms  bot move ${disp} 0 0 units box

shell rm gsfe

variable        a loop ${stepm}
label           loopa

variable        rdisp equal ($a-1)/${stepn}

displace_atoms  bot move -${disp} 0 0 units box

compute         peratom all pe/atom
compute         eatoms all reduce sum c_peratom
compute         ematoms middle reduce sum c_peratom

variable        gsfe equal c_eatoms/${area}*1.60218*10000
variable        abe equal c_ematoms/${area}*1.60218*10000

thermo          10
thermo_style    custom step pe c_eatoms pxz pyy

fix		1 boundary setforce 0.0 0.0 0.0
fix		2 mobile setforce 0.0 NULL 0.0

min_style       cg
minimize	1e-20 1e-20 10000 10000

print           "${rdisp} ${gsfe} ${abe}" append gsfe
shell mkdir 10_increament_dump
write_data 10_increament_dump/step_${a}.lmp

unfix           1
unfix		2
uncompute       peratom
uncompute       eatoms
uncompute       ematoms 

next            a
jump             gsfe.in loopa